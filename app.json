{
  "expo": {
    "name": "Orbit Media Solutions",
    "slug": "orbit-media",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/orbitLogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/orbitLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.orbitmedia.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "This app uses FaceID to log you in securely.",
        "LSApplicationQueriesSchemes": [
          "mailto"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.orbitmedia.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/orbitLogo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-dev-client",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends.",
          "cameraPermission": "The app accesses your camera to let you take a profile picture."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "extraMavenRepos": [
              "../../node_modules/react-native-mmkv/android"
            ]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2aef075c-2544-4fe6-9448-ce8815849053"
      }
    },
    "owner": "orbitmedia"
  }
}
